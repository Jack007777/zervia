{
  "name": "@zervia/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "corepack pnpm --filter @zervia/shared build && ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "corepack pnpm --filter @zervia/shared build && tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "corepack pnpm exec jest --config ./jest.config.ts",
    "test:booking-concurrency": "node scripts/booking-concurrency-test.js",
    "seed:virtual:de": "node scripts/seed-virtual-businesses.js --count 200",
    "seed:virtual:de:purge": "node scripts/seed-virtual-businesses.js --count 200 --purge-virtual"
  },
  "dependencies": {
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "@nestjs/common": "^11.0.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.11",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.11",
    "@nestjs/swagger": "^11.2.0",
    "@zervia/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "luxon": "^3.7.2",
    "mongoose": "^8.12.1",
    "nest-winston": "^1.10.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.2"
  }
}
